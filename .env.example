# ── App ───────────────────────────────────────────
APP_NAME=SmartApply
APP_ENV=development
DEBUG=True
DEMO_MODE=True

# ── Security ──────────────────────────────────────
SECRET_KEY=your_super_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
RESET_TOKEN_EXPIRE_MINUTES=30

# ── MongoDB ───────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=smartapply

# ── Cloudflare R2 ────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=smart-apply
R2_PUBLIC_URL=

# ── Brevo (Email) ─────────────────────────────────
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@smartapply.ai
BREVO_SENDER_NAME=SmartApply

# ── NVIDIA NIM (AI) ───────────────────────────────
NIM_API_KEYS=

# ── Frontend ──────────────────────────────────────
FRONTEND_URL=http://localhost:5173
REQUIRE_EMAIL_VERIFICATION=False

# ── Google OAuth ──────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Extension ─────────────────────────────────────
CHROME_EXTENSION_ID=

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
