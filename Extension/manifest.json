{
  "manifest_version": 3,
  "name": "SmartApply \u2014 Auto Apply Bot",
  "version": "1.1.0",
  "description": "AI-powered job auto-apply automation for LinkedIn and Naukri.",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "cookies"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://www.naukri.com/*",
    "https://naukri.com/*",
    "https://www.smartapplies.app/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*"
      ],
      "js": [
        "content/bundle.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://www.naukri.com/*",
        "https://naukri.com/*"
      ],
      "js": [
        "content/naukri-bundle.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://www.internshala.com/*",
        "https://internshala.com/*"
      ],
      "js": [
        "content/internshala-bundle.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "externally_connectable": {
    "matches": [
      "https://www.smartapplies.app/*",
      "https://smartapplies.app/*"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*"
      ],
      "matches": [
        "https://www.linkedin.com/*",
        "https://www.naukri.com/*"
      ]
    }
  ]
}